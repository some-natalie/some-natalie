{
  "name": "Jekyll website",
  "build": {
        "dockerfile": "Dockerfile",
        "args": {}
    },
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Website"
    }
  },
  "remoteUser": "nonroot",
  "postCreateCommand": {
    "bundle": "bundle install --retry 5 --jobs 20",
    "first-welcome": "sudo echo '\n🌺 Have a nice day! 🌺' >> /workspaces/.codespaces/shared/first-run-notice.txt"
  },
  "postAttachCommand": "bundle exec jekyll serve --host 0.0.0.0"
}
