{
  "name": "Jekyll website",
  "image": "mcr.microsoft.com/vscode/devcontainers/ruby:3-bullseye",
  "features": {
    "git-lfs": "latest"
  },
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Website"
    }
  },
  "customizations": {
    "codespaces": {
      "repositories": {
        "some-natalie/work-stuff": {
          "permissions": {
            "contents": "write",
            "pull_requests": "write"
          }
        }
      }
    }
  },
  "postCreateCommand": {
    "bundle": "bundle",
    "clone-repos": ".devcontainer/post-create.sh"
  },
  "postAttachCommand": {
    "open-repos": "bundle exec jekyll serve --livereload",
    "reminder": "echo \"Remember to run './load-workspace.sh' to open the other repositories.\""
  }
}
